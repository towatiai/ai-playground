{
	"$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
	"productName": "ai-playground",
	"version": "0.1.0",
	"identifier": "com.tauri.dev",
	"build": {
		"frontendDist": "../build",
		"devUrl": "http://localhost:1420",
		"beforeDevCommand": "pnpm dev",
		"beforeBuildCommand": "pnpm build"
	},
	"app": {
		"windows": [
			{
				"title": "AI Playground",
				"width": 800,
				"height": 600,
				"resizable": true,
				"fullscreen": false,
				"titleBarStyle": "Overlay",
				"hiddenTitle": true
			}
		],
		"security": {
			"csp": null,
			"capabilities": [
				{
					"identifier": "draggable-window",
					"windows": ["*"],
					"permissions": ["core:window:allow-start-dragging"]
				}
			]
		}
	},
	"bundle": {
		"active": true,
		"targets": "all",
		"icon": [
			"icons/32x32.png",
			"icons/128x128.png",
			"icons/128x128@2x.png",
			"icons/icon.icns",
			"icons/icon.ico"
		]
	}
}
